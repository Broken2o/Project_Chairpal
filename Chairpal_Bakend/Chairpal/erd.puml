@startuml

hide methods
hide stereotypes
skinparam linetype ortho

entity "ai_recommendations" as ai_recommendations {
    * id : BIGINT(20) <<PK>>
    wheelchair_id : BIGINT(20)
    heart_rate : DOUBLE
    heart_rate_status : ENUM('LOW','MEDIUM','CRITICAL')
    temperature : DOUBLE
    temperature_status : ENUM('LOW','MEDIUM','CRITICAL')
    mpu_angle : DOUBLE
    fall_status : ENUM('LOW','MEDIUM','CRITICAL')
    type : VARCHAR(255)
    risk_level : ENUM('LOW','MEDIUM','CRITICAL')
    reason : TEXT
    recommendation : TEXT
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "ai_status_logs" as ai_status_logs {
    * id : BIGINT(20) <<PK>>
    e_chair_id : BIGINT(20)
    event_type : VARCHAR(255)
    component_name : VARCHAR(255)
    message : TEXT
    decision_context : LONGTEXT
    details : LONGTEXT
    timestamp_ms : BIGINT(20)
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "audit_logs" as audit_logs {
    * id : BIGINT(20) <<PK>>
