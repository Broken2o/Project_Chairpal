<?xml version="1.0" ?>
<sdf version="1.7">
  <world name="stairs_camera_test">
    <physics name="2ms" type="ignored">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin name="gz::sim::systems::Physics" filename="gz-sim-physics-system"/>
    <plugin name="gz::sim::systems::UserCommands" filename="gz-sim-user-commands-system"/>
    <plugin name="gz::sim::systems::SceneBroadcaster" filename="gz-sim-scene-broadcaster-system"/>
    <plugin name="gz::sim::systems::Sensors" filename="gz-sim-sensors-system">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin name="gz::sim::systems::Imu" filename="gz-sim-imu-system"/>

    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>60 60</size>
            </plane>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="wall_north">
      <static>true</static>
      <pose>0 4 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>12 0.15 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>12 0.15 2.0</size></box></geometry></visual>
      </link>
    </model>
    <model name="wall_south">
      <static>true</static>
      <pose>0 -4 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>12 0.15 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>12 0.15 2.0</size></box></geometry></visual>
      </link>
    </model>
    <model name="wall_east">
      <static>true</static>
      <pose>6 0 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.15 8 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.15 8 2.0</size></box></geometry></visual>
      </link>
    </model>
    <model name="wall_west">
      <static>true</static>
      <pose>-6 0 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.15 8 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.15 8 2.0</size></box></geometry></visual>
      </link>
    </model>

    <!-- Realistic staircase for camera testing -->
    <model name="staircase_real">
      <static>true</static>
      <pose>3.6 -2.2 0 0 0 3.14159</pose>

      <link name="step_1">
        <pose>0 0 0.075 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.30 1.20 0.15</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.30 1.20 0.15</size></box></geometry><material><ambient>0.85 0.35 0.15 1</ambient><diffuse>0.85 0.35 0.15 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
      </link>
      <link name="step_2">
        <pose>-0.30 0 0.225 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.30 1.20 0.15</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.30 1.20 0.15</size></box></geometry><material><ambient>0.85 0.35 0.15 1</ambient><diffuse>0.85 0.35 0.15 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
      </link>
      <link name="step_3">
        <pose>-0.60 0 0.375 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.30 1.20 0.15</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.30 1.20 0.15</size></box></geometry><material><ambient>0.85 0.35 0.15 1</ambient><diffuse>0.85 0.35 0.15 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
      </link>
      <link name="step_4">
        <pose>-0.90 0 0.525 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.30 1.20 0.15</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.30 1.20 0.15</size></box></geometry><material><ambient>0.85 0.35 0.15 1</ambient><diffuse>0.85 0.35 0.15 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
      </link>
      <link name="step_5">
        <pose>-1.20 0 0.675 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.30 1.20 0.15</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.30 1.20 0.15</size></box></geometry><material><ambient>0.85 0.35 0.15 1</ambient><diffuse>0.85 0.35 0.15 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
      </link>
      <link name="step_6">
        <pose>-1.50 0 0.825 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.30 1.20 0.15</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.30 1.20 0.15</size></box></geometry><material><ambient>0.85 0.35 0.15 1</ambient><diffuse>0.85 0.35 0.15 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
      </link>

      <link name="landing">
        <pose>-2.10 0 0.825 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.90 1.20 0.15</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.90 1.20 0.15</size></box></geometry><material><ambient>0.90 0.40 0.20 1</ambient><diffuse>0.90 0.40 0.20 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
      </link>
    </model>
    <!-- Photo Billboard for Camera Testing -->
    <model name="photo_billboard">
      <static>true</static>
      <!-- Placed 3 meters in front of the chair's spawn point -->
      <pose>3 0 1 0 0 0</pose> 
      <link name="link">
        <collision name="collision"><geometry><box><size>0.1 2 2</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.1 2 2</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <pbr>
              <metal>
                <albedo_map>file:///home/ayadiab/chair_ws/src/medical_wheelchair/worlds/stair1.jpg</albedo_map>
                <roughness>1.0</roughness>
                <metalness>0.0</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
